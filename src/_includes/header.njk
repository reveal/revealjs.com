<header class="header {% if id == "home" %}sticky{% else %}fixed{% endif %} flex h-16 items-center top-0 w-full z-30 bg-gray-100 py-2 border-b border-gray-300">
  <div class="w-full relative max-w-screen-xl mx-auto px-6 flex flex-row items-center justify-between">
    <div class="header-left mr-6 flex-shrink-0">
      <a class="header-logo block" href="/" title="reveal.js home">
        <span class="header-logo-desktop hidden sm:block">
          <img class="header-logo-dark" src="/images/logo/reveal-white-text.svg" alt="reveal.js logo" width="142">
          <img class="header-logo-light" src="/images/logo/reveal-black-text.svg" alt="reveal.js logo" width="142">
        </span>
        <img class="block sm:hidden" src="/images/logo/reveal-symbol.svg" alt="reveal.js logo" style="width: 40px">
      </a>
      <!--<a class="header-cta py-3 px-2 -mx-2 text-gray-800 hover:text-gray-900 rounded font-semibold" href="/installation">Get Started</a>-->
    </div>

    <div class="search relative mr-2 flex-grow max-w-3xl sm:mr-6">
      <input class="search-input appearance-none h-10 w-full inline-block py-1 px-4 bg-gray-300 border-2 border-gray-300 outline-none rounded-full placeholder-gray-600 text-gray-800 hover:text-gray-900 focus:border-yellow-400" placeholder="Search reveal.js..." />
      <kbd class="search-shortcut absolute right-4 py-2 top-0.5 rounded-lg text-sm text-gray-600 pointer-events-none hidden sm:inline-block"><span class="search-shortcut-modifier text-lg leading-none align-middle mr-0.5">⌘</span>K</kbd>
      <div class="search-results overflow-hidden fixed left-4 right-4 top-100 p-2 mt-2 rounded-lg shadow-2xl text-sm lg:absolute lg:left-auto lg:right-auto lg:min-w-full" data-state="no-term"></div>
    </div>

    <nav class="header-nav hidden lg:flex">

      <ul class="menu flex flex-col lg:flex-row items-center list-reset text-base">
        {% if locales.length %}
        <li class="relative header-lang">
          <a class="inline-block py-3 px-4 text-gray-800 hover:text-gray-900 rounded align-middle">
            {% include "images/icons/translate.svg" %}
          </a>
          <div class="header-lang-select absolute shadow-2xl px-2 py-2 text-gray-800 rounded-lg align-middle focus:outline-none">
          {% for localed in locales -%}
        <a href="/{{ localed.code }}/{{ page.url | replace(locale, '') | replace('/', '') }}" hreflang="{{ localed.code }}" class="block px-4 py-2 text-sm text-gray-700 hover:text-gray-900">{{ localed.label }}</a>
  {% endfor -%}
          </div>
        </li>
        {% endif %}
        <li>
          <button type="button" data-theme-toggle class="theme-toggle inline-flex items-center justify-center py-3 px-4 text-gray-800 hover:text-gray-900 rounded align-middle" aria-label="Switch theme">
            <svg class="theme-toggle-icon-sun" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="12" cy="12" r="4" style="stroke: currentColor; stroke-width: 2" />
              <path d="M12 2V5" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M12 19V22" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M2 12H5" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M19 12H22" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M4.93 4.93L7.05 7.05" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M16.95 16.95L19.07 19.07" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M16.95 7.05L19.07 4.93" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
              <path d="M4.93 19.07L7.05 16.95" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round" />
            </svg>
            <svg class="theme-toggle-icon-moon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 14.19A8 8 0 0 1 9.81 4a8 8 0 1 0 10.19 10.19Z" style="stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round" />
            </svg>
          </button>
        </li>
        <li>
          <a class="inline-block py-3 px-4 text-gray-800 hover:text-gray-900 rounded align-middle" href="{{ site.urls.twitter }}">
            {% include "images/icons/twitter.svg" %}
          </a>
        </li>
        <li>
          <a class="inline-block py-3 px-4 text-gray-800 hover:text-gray-900 rounded align-middle" href="{{ site.urls.github }}">
            {% include "images/icons/github.svg" %}
          </a>
        </li>

      </ul>

    </nav>

    <nav class="header-nav lg:hidden flex">

      <ul class="menu flex flex-row items-center list-reset text-sm">

        {# <li>
          <a class="inline-block p-2 text-gray-800 hover:text-gray-900 rounded align-middle" href="{{ site.urls.twitter }}">
            {% include "images/icons/twitter.svg" %}
          </a>
        </li> #}
        <li>
          <a class="inline-block p-2 mr-1 text-gray-800 hover:text-gray-900 rounded align-middle" href="{{ site.urls.github }}">
            {% include "images/icons/github.svg" %}
          </a>
        </li>
        <li>
          <button class="menu-toggle inline-block py-1 pl-2 text-gray-800 hover:text-gray-900">
            <svg viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
              <line class="line1" x1="0" y1="8" x2="24" y2="8" style="stroke: currentColor; stroke-width: 2" />
              <line class="line2" x1="0" y1="16" x2="24" y2="16" style="stroke: currentColor; stroke-width: 2" />
            </svg>
          </button>
        </li>

      </ul>

    </nav>
  </div>
</header>
